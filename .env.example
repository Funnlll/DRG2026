# PostgreSQL is optional. If omitted, the app falls back to data/data.json.
# DATABASE_URL=postgresql://user:password@host:5432/database

# Email notification settings.
# For QQ Mail, EMAIL_PASS must be the SMTP authorization code, not the login password.
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_qq_email@qq.com
EMAIL_PASS=your_qq_smtp_authorization_code
EMAIL_TO=676921772@qq.com
